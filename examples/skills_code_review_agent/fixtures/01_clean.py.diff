--- a/src/calculator.py
+++ b/src/calculator.py
@@ -0,0 +1,20 @@
+"""Simple calculator module."""
+
+
+def add(a: int, b: int) -> int:
+    """Add two numbers."""
+    return a + b
+
+
+def subtract(a: int, b: int) -> int:
+    """Subtract two numbers."""
+    return a - b
+
+
+def multiply(a: int, b: int) -> int:
+    """Multiply two numbers."""
+    return a * b
+
+
+def divide(a: int, b: int) -> int:
+    """Divide two numbers."""
+    return a // b